{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "clean-terminal",
            "type": "shell",
            "command": "printf '\\033c'"
        },
        {
            "label": "build",
            "dependsOn": "clean-terminal",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "test",
            "dependsOn": "clean-terminal",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "-p:EnableUnitTesting=true",
                "--verbosity",
                "normal"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}