{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Godot",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "/Applications/Godot_mono.app/Contents/MacOS/Godot",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
        },
        {
            "name": "Launch Godot Editor",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "build",
            "command": "/Applications/Godot_mono.app/Contents/MacOS/Godot --editor --path ${workspaceFolder}",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Attach to Godot Editor",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "justMyCode": false
        },
        {
            "name": "Python: DEBUG main.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "python": "${workspaceFolder}/venv/bin/python"
        },
        {
            "name": "Python: DEBUG build_shader.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/build_shader.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "python": "${workspaceFolder}/venv/bin/python"
        }
    ]
}