{
  "name": "ThreeJS GLSL",
  "version": "1.0",
  "file_extensions": [
    "glsl"
  ],
  "coordinates": {
    "up": "+y",
    "right": "+x",
    "forward": "-z",
    "handedness": "right"
  },
  "nodes": {
    "surface": {
      "template": "precision highp float;\n{{meta}}\n#ifndef SHADING_UNLIT\n#ifndef SHADING_TOON\n#ifndef SHADING_PBR\n#define SHADING_PBR 1\n#endif\n#endif\n#endif\n\n// Varyings from default vertex shader\nvarying vec2 vUv;\nvarying vec3 vNormal;\nvarying vec3 vObjectNormal;\nvarying vec3 vViewPosition;\n\n// Preview lighting and timing uniforms (provided by preview panel)\n// Three-point lighting rig: key, fill, and rim\nuniform vec3 uKeyDir;\nuniform vec3 uKeyColor;\nuniform vec3 uFillDir;\nuniform vec3 uFillColor;\nuniform vec3 uRimDir;\nuniform vec3 uRimColor;\nuniform vec3 uAmbient;\nuniform float uExposure;\nuniform float uTime;\n\n// PBR helpers\nfloat saturate(float x) { return clamp(x, 0.0, 1.0); }\nvec3 saturate(vec3 x) { return clamp(x, vec3(0.0), vec3(1.0)); }\nfloat D_GGX(float NoH, float a) { float a2 = a*a; float f = (NoH * NoH) * (a2 - 1.0) + 1.0; return a2 / (3.14159265 * f * f + 1e-5); }\nfloat V_SmithGGXCorrelated(float NoV, float NoL, float a) { float a2 = a*a; float gv = NoL * sqrt((NoV - NoV * a2) * NoV + a2); float gl = NoV * sqrt((NoL - NoL * a2) * NoL + a2); return 0.5 / max(gv + gl, 1e-5); }\nvec3 F_Schlick(vec3 f0, float VoH) { float f = pow(1.0 - VoH, 5.0); return f + (1.0 - f) * f0; }\nvec3 BRDF_Lambert(vec3 diffuseColor) { return diffuseColor / 3.14159265; }\n\n// Exposed uniforms (from graph)\n{{exposed_nodes}}\n\n// Graph internal code\n{{internal_nodes}}\n"
    },
    "vertex_pass": {
      "template": "// __VERTEX_PASS_BEGIN__\n{{internal_nodes}}// __VERTEX_PASS_END__\n"
    },
    "fragment_pass": {
      "template": "void main() {\n{{internal_nodes}}\n}\n",
      "properties": {
        "blend_mode": {
          "opaque": { "template": "", "placement": "meta" },
          "transparent": { "template": "// three: enable blending (transparent)\n", "placement": "meta" },
          "add": { "template": "// three: enable additive blending\n", "placement": "meta" },
          "multiply": { "template": "// three: enable multiply blending\n", "placement": "meta" }
        }
      }
    },
    "color": {
      "template": "vec4 {{name}} = vec4({{inputs:0}});"
    },
    "float": {
      "template": "float {{name}} = {{inputs:0}};"
    },
    "float2": {
      "template": "vec2 {{name}} = vec2({{inputs:0}});"
    },
    "float3": {
      "template": "vec3 {{name}} = vec3({{inputs:0}});"
    },
    "float4": {
      "template": "vec4 {{name}} = vec4({{inputs:0}});"
    },
    "fragment_output": {
      "template": "#if defined(SHADING_PBR)\nvec3 baseColor = vec3({{inputs:0}});\nfloat roughness = clamp({{inputs:1}}, 0.04, 1.0);\nfloat metalness = clamp({{inputs:2}}, 0.0, 1.0);\nvec3 emission = vec3({{inputs:3}}) * {{inputs:23}};\nvec3 nrm_in = vec3({{inputs:4}});\nfloat alpha = {{inputs:5}};\nfloat specular = clamp({{inputs:6}}, 0.0, 1.0);\nfloat ao = clamp({{inputs:7}}, 0.0, 1.0);\nfloat aoLightAffect = clamp({{inputs:8}}, 0.0, 1.0);\nfloat clearcoat = clamp({{inputs:9}}, 0.0, 1.0);\nfloat clearcoatRoughness = clamp({{inputs:10}}, 0.04, 1.0);\nfloat transmission = clamp({{inputs:11}}, 0.0, 1.0);\nfloat transmissionRoughness = clamp({{inputs:12}}, 0.0, 1.0);\nfloat subsurface = clamp({{inputs:13}}, 0.0, 1.0);\nvec3 subsurfaceColor = vec3({{inputs:14}});\nfloat sheen = clamp({{inputs:15}}, 0.0, 1.0);\nvec3 sheenColor = vec3({{inputs:16}});\nfloat anisotropy = clamp({{inputs:17}}, -0.9, 0.9);\nvec3 anisotropyDir = normalize(vec3({{inputs:18}}) + vec3(1e-4, 0.0, 0.0));\nfloat ior = max({{inputs:19}}, 1.0);\nvec3 refractionColor = vec3({{inputs:20}});\nfloat thickness = max({{inputs:21}}, 0.0);\nvec3 backlight = vec3({{inputs:22}});\nvec3 N = normalize(vNormal + (nrm_in - vec3(0.0, 0.0, 1.0)));\nvec3 V = normalize(vViewPosition);\nfloat NoV = saturate(dot(N, V));\nfloat anisotropyFactor = 1.0 - abs(anisotropy) * 0.5;\nfloat a = max(0.001, (roughness * roughness) * anisotropyFactor);\nvec3 f0 = mix(vec3(0.04 * mix(1.0, 2.0, specular)), baseColor, metalness);\n\nvec3 Lo = vec3(0.0);\n\n// Key light (safe normalize)\n{\n  float lenL = max(length(uKeyDir), 1e-6);\n  vec3 L = uKeyDir / lenL;\n  vec3 lightColor = uKeyColor;\n  vec3 H = normalize(V + L);\n  float NoL = saturate(dot(N, L));\n  float NoH = saturate(dot(N, H));\n  float VoH = saturate(dot(V, H));\n  float D = D_GGX(NoH, a);\n  float Vis = V_SmithGGXCorrelated(NoV, NoL, a);\n  vec3  F = F_Schlick(f0, VoH);\n  vec3  Fr = (D * Vis) * F;\n  vec3  kd = (1.0 - F) * (1.0 - metalness);\n  vec3  diffuse = BRDF_Lambert(baseColor) * kd;\n  Lo += (diffuse + Fr) * (lightColor * NoL);\n  if (clearcoat > 0.001) {\n    float clearA = max(0.001, clearcoatRoughness * clearcoatRoughness);\n    float Dc = D_GGX(NoH, clearA);\n    float Vc = V_SmithGGXCorrelated(NoV, NoL, clearA);\n    vec3 Fc = F_Schlick(vec3(0.04), VoH);\n    Lo += clearcoat * (Dc * Vc) * Fc * (lightColor * NoL);\n  }\n}\n// Fill light (safe normalize)\n{\n  float lenL = max(length(uFillDir), 1e-6);\n  vec3 L = uFillDir / lenL;\n  vec3 lightColor = uFillColor;\n  vec3 H = normalize(V + L);\n  float NoL = saturate(dot(N, L));\n  float NoH = saturate(dot(N, H));\n  float VoH = saturate(dot(V, H));\n  float D = D_GGX(NoH, a);\n  float Vis = V_SmithGGXCorrelated(NoV, NoL, a);\n  vec3  F = F_Schlick(f0, VoH);\n  vec3  Fr = (D * Vis) * F;\n  vec3  kd = (1.0 - F) * (1.0 - metalness);\n  vec3  diffuse = BRDF_Lambert(baseColor) * kd;\n  Lo += (diffuse + Fr) * (lightColor * NoL);\n  if (clearcoat > 0.001) {\n    float clearA = max(0.001, clearcoatRoughness * clearcoatRoughness);\n    float Dc = D_GGX(NoH, clearA);\n    float Vc = V_SmithGGXCorrelated(NoV, NoL, clearA);\n    vec3 Fc = F_Schlick(vec3(0.04), VoH);\n    Lo += clearcoat * (Dc * Vc) * Fc * (lightColor * NoL);\n  }\n}\n// Rim light (safe normalize)\n{\n  float lenL = max(length(uRimDir), 1e-6);\n  vec3 L = uRimDir / lenL;\n  vec3 lightColor = uRimColor;\n  vec3 H = normalize(V + L);\n  float NoL = saturate(dot(N, L));\n  float NoH = saturate(dot(N, H));\n  float VoH = saturate(dot(V, H));\n  float D = D_GGX(NoH, a);\n  float Vis = V_SmithGGXCorrelated(NoV, NoL, a);\n  vec3  F = F_Schlick(f0, VoH);\n  vec3  Fr = (D * Vis) * F;\n  vec3  kd = (1.0 - F) * (1.0 - metalness);\n  vec3  diffuse = BRDF_Lambert(baseColor) * kd;\n  Lo += (diffuse + Fr) * (lightColor * NoL);\n  if (clearcoat > 0.001) {\n    float clearA = max(0.001, clearcoatRoughness * clearcoatRoughness);\n    float Dc = D_GGX(NoH, clearA);\n    float Vc = V_SmithGGXCorrelated(NoV, NoL, clearA);\n    vec3 Fc = F_Schlick(vec3(0.04), VoH);\n    Lo += clearcoat * (Dc * Vc) * Fc * (lightColor * NoL);\n  }\n}\n\n// Ambient term\nLo += uAmbient * baseColor;\nLo = mix(baseColor * aoLightAffect, Lo, ao);\n\nvec3 extras = vec3(0.0);\nextras += subsurfaceColor * subsurface * pow(1.0 - NoV, 1.5) * (1.0 + thickness);\nextras += sheenColor * sheen * pow(1.0 - NoV, 4.0);\nextras += backlight * pow(saturate(dot(-N, V)), 2.0) * thickness;\n\nvec3 color = saturate((Lo + extras + emission) * uExposure);\n\nvec3 refractDir = refract(-V, N, 1.0 / ior);\nvec3 transmissionColor = mix(color, refractionColor, transmissionRoughness);\ncolor = mix(color, transmissionColor, transmission);\nfloat outAlpha = mix(alpha, clamp(1.0 - transmission, 0.0, 1.0), transmission);\n\ngl_FragColor = vec4(color, outAlpha);\n#elif defined(SHADING_TOON)\nvec3 baseColor = vec3({{inputs:0}});\nfloat alpha = {{inputs:5}};\nvec3 N = normalize(vNormal);\nfloat lenL = max(length(uKeyDir), 1e-6);\nvec3 L = uKeyDir / lenL;\nfloat ndl = max(dot(N, L), 0.0);\nfloat ramp = step(0.2, ndl) + step(0.6, ndl);\nramp = clamp(ramp, 0.0, 1.0);\nvec3 color = mix(baseColor * 0.6, baseColor, ramp) + vec3({{inputs:3}}) * {{inputs:23}};\ngl_FragColor = vec4(color, alpha);\n#else\n// Unlit fallback\ngl_FragColor = vec4({{inputs:0}} + vec3({{inputs:3}}) * {{inputs:23}}, {{inputs:5}});\n#endif",
      "properties": {
        "shading_model": {
          "pbr": {
            "template": "#define SHADING_PBR 1",
            "placement": "meta"
          },
          "unlit": {
            "template": "#define SHADING_UNLIT 1",
            "placement": "meta"
          },
          "toon": {
            "template": "#define SHADING_TOON 1",
            "placement": "meta"
          }
        },
        "enable_transmission": { "true": { "template": "// transmission enabled\n", "placement": "meta" } },
        "enable_sss": { "true": { "template": "// subsurface_scattering enabled\n", "placement": "meta" } },
        "enable_sheen": { "true": { "template": "// sheen enabled\n", "placement": "meta" } },
        "enable_anisotropy": { "true": { "template": "// anisotropic enabled\n", "placement": "meta" } },
        "enable_refraction": { "true": { "template": "// refraction enabled\n", "placement": "meta" } },
        "enable_backlight": { "true": { "template": "// backlight enabled\n", "placement": "meta" } }
      }
    },
    "add": {
      "template": "{{type}} {{name}} = {{inputs:0}} + {{inputs:1}};"
    },
    "multiply": {
      "template": "{{type}} {{name}} = {{inputs:0}} * {{inputs:1}};"
    },
    "subtract": {
      "template": "{{type}} {{name}} = {{inputs:0}} - {{inputs:1}};"
    },
    "divide": {
      "template": "{{type}} {{name}} = {{inputs:0}} / {{inputs:1}};"
    },
    "remainder": {
      "template": "{{type}} {{name}} = mod({{inputs:0}}, {{inputs:1}});"
    },
    "power": {
      "template": "{{type}} {{name}} = pow({{inputs:0}}, {{inputs:1}});"
    },
    "max": {
      "template": "{{type}} {{name}} = max({{inputs:0}}, {{inputs:1}});"
    },
    "min": {
      "template": "{{type}} {{name}} = min({{inputs:0}}, {{inputs:1}});"
    },
    "greater_than": {
      "template": "float {{name}} = {{inputs:0}} > {{inputs:1}} ? 1.0 : 0.0;"
    },
    "less_than": {
      "template": "float {{name}} = {{inputs:0}} < {{inputs:1}} ? 1.0 : 0.0;"
    },
    "equal": {
      "template": "float {{name}} = abs({{inputs:0}} - {{inputs:1}}) <= {{inputs:2}} ? 1.0 : 0.0;"
    },
    "select": {
      "template": "{{type}} {{name}} = mix({{inputs:2}}, {{inputs:1}}, step(0.5, {{inputs:0}}));"
    },
    "atan2": {
      "template": "float {{name}} = atan({{inputs:0}}, {{inputs:1}});"
    },
    "reflect": {
      "template": "vec3 {{name}} = reflect({{inputs:0}}, {{inputs:1}});"
    },
    "fresnel": {
      "template": "float {{name}} = saturate({{inputs:2}} + {{inputs:3}} * pow(max(0.0, 1.0 - dot(normalize({{inputs:0}}), normalize({{inputs:1}}))), {{inputs:4}}));"
    },
    "step": {
      "template": "{{type}} {{name}} = step({{inputs:0}}, {{inputs:1}});"
    },
    "cross": {
      "template": "vec3 {{name}} = cross({{inputs:0}}, {{inputs:1}});"
    },
    "dot": {
      "template": "float {{name}} = dot({{inputs:0}}, {{inputs:1}});"
    },
    "lerp": {
      "template": "{{type}} {{name}} = mix({{inputs:0}}, {{inputs:1}}, {{inputs:2}});"
    },
    "abs": {
      "template": "{{type}} {{name}} = abs({{inputs:0}});"
    },
    "acos": {
      "template": "{{type}} {{name}} = acos({{inputs:0}});"
    },
    "asin": {
      "template": "{{type}} {{name}} = asin({{inputs:0}});"
    },
    "atan": {
      "template": "{{type}} {{name}} = atan({{inputs:0}});"
    },
    "ceil": {
      "template": "{{type}} {{name}} = ceil({{inputs:0}});"
    },
    "clamp": {
      "template": "{{type}} {{name}} = clamp({{inputs:0}}, {{inputs:1}}, {{inputs:2}});"
