      "template": "float {{name}}_hash(vec3 p) {\n  return fract(sin(dot(p, vec3(127.1, 311.7, 74.7))) * 43758.5453);\n}\nvec3 {{name}}_p = vec3({{inputs:0}}) * {{inputs:1}} + vec3({{inputs:2}});\nvec3 {{name}}_i = floor({{name}}_p);\nvec3 {{name}}_f = fract({{name}}_p);\n{{name}}_f = {{name}}_f * {{name}}_f * (3.0 - 2.0 * {{name}}_f);\nfloat {{name}}_n000 = {{name}}_hash({{name}}_i + vec3(0.0, 0.0, 0.0));\nfloat {{name}}_n100 = {{name}}_hash({{name}}_i + vec3(1.0, 0.0, 0.0));\nfloat {{name}}_n010 = {{name}}_hash({{name}}_i + vec3(0.0, 1.0, 0.0));\nfloat {{name}}_n110 = {{name}}_hash({{name}}_i + vec3(1.0, 1.0, 0.0));\nfloat {{name}}_n001 = {{name}}_hash({{name}}_i + vec3(0.0, 0.0, 1.0));\nfloat {{name}}_n101 = {{name}}_hash({{name}}_i + vec3(1.0, 0.0, 1.0));\nfloat {{name}}_n011 = {{name}}_hash({{name}}_i + vec3(0.0, 1.0, 1.0));\nfloat {{name}}_n111 = {{name}}_hash({{name}}_i + vec3(1.0, 1.0, 1.0));\nfloat {{name}}_nx00 = mix({{name}}_n000, {{name}}_n100, {{name}}_f.x);\nfloat {{name}}_nx10 = mix({{name}}_n010, {{name}}_n110, {{name}}_f.x);\nfloat {{name}}_nx01 = mix({{name}}_n001, {{name}}_n101, {{name}}_f.x);\nfloat {{name}}_nx11 = mix({{name}}_n011, {{name}}_n111, {{name}}_f.x);\nfloat {{name}}_nxy0 = mix({{name}}_nx00, {{name}}_nx10, {{name}}_f.y);\nfloat {{name}}_nxy1 = mix({{name}}_nx01, {{name}}_nx11, {{name}}_f.y);\nfloat {{name}} = mix({{name}}_nxy0, {{name}}_nxy1, {{name}}_f.z);"
