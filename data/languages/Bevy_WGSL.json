{
  "name": "Bevy WGSL",
  "version": "1.0",
  "file_extensions": [
    "wgsl"
  ],
  "coordinates": {
    "up": "+y",
    "right": "+x",
    "forward": "-z",
    "handedness": "right"
  },
  "types": {
    "float": { "code": "f32", "constructor": "f32", "zero": "0.0", "components": 1 },
    "float2": { "code": "vec2<f32>", "constructor": "vec2<f32>", "zero": "vec2<f32>(0.0, 0.0)", "components": 2 },
    "float3": { "code": "vec3<f32>", "constructor": "vec3<f32>", "zero": "vec3<f32>(0.0, 0.0, 0.0)", "components": 3 },
    "float4": { "code": "vec4<f32>", "constructor": "vec4<f32>", "zero": "vec4<f32>(0.0, 0.0, 0.0, 0.0)", "components": 4 },
    "matrix2": { "code": "mat2x2<f32>", "constructor": "mat2x2<f32>", "zero": "mat2x2<f32>(1.0)", "components": 2 },
    "matrix3": { "code": "mat3x3<f32>", "constructor": "mat3x3<f32>", "zero": "mat3x3<f32>(1.0)", "components": 3 },
    "matrix4": { "code": "mat4x4<f32>", "constructor": "mat4x4<f32>", "zero": "mat4x4<f32>(1.0)", "components": 4 }
  },
  "capabilities": { "allowRgbSwizzle": false, "vectorCtorScalarSplat": true },
  "nodes": {
    "surface": {
      "template": [
        "// OpenShaderGraph - Bevy WGSL target",
        "// This code is generated and intended to be embedded into a Bevy shader pipeline.",
        "{{meta}}",
        "// Exposed graph-level constants/uniforms (as declared in nodes)",
        "{{exposed_nodes}}",
        "// Graph entrypoints",
        "{{internal_nodes}}"
      ]
    },
    "vertex_pass": {
      "template": [
        "// Vertex pass placeholder (expand as needed)",
        "// In Bevy, define a proper @vertex entry if vertex graph is used.",
        "// {{internal_nodes}}"
      ]
    },
    "fragment_pass": {
      "template": [
        "@fragment fn main() -> @location(0) vec4<f32> {",
        "{{internal_nodes}}",
        "// Fallback return in case no fragment_output node writes a value",
        "return vec4<f32>(0.0, 0.0, 0.0, 1.0);",
        "}"
      ],
      "properties": {
        "blend_mode": {
          "opaque": { "template": "", "placement": "meta" },
          "transparent": { "template": "", "placement": "meta" },
          "add": { "template": "", "placement": "meta" },
          "multiply": { "template": "", "placement": "meta" }
        }
      }
    },
    "color": {
      "template": "let {{name}}: vec4<f32> = vec4<f32>({{inputs:0}});"
    },
    "float": {
      "template": "let {{name}}: f32 = {{inputs:0}};"
    },
    "float2": {
      "template": "let {{name}}: vec2<f32> = vec2<f32>({{inputs:0}});"
    },
    "float3": {
      "template": "let {{name}}: vec3<f32> = vec3<f32>({{inputs:0}});"
    },
    "float4": {
      "template": "let {{name}}: vec4<f32> = vec4<f32>({{inputs:0}});"
    },
    "fragment_output": {
      "template": [
        "// Compose final fragment color (unlit baseline)",
        "let _base: vec3<f32> = vec3<f32>({{inputs:0}});",
        "let _emission: vec3<f32> = vec3<f32>({{inputs:3}}) * {{inputs:23}};",
        "let _alpha: f32 = {{inputs:5}};",
        "return vec4<f32>(clamp(_base + _emission, vec3<f32>(0.0, 0.0, 0.0), vec3<f32>(1.0, 1.0, 1.0)), clamp(_alpha, 0.0, 1.0));"
      ],
      "properties": {
        "shading_model": {
          "pbr": { "template": "", "placement": "meta" },
          "unlit": { "template": "", "placement": "meta" },
          "toon": { "template": "", "placement": "meta" }
        }
      }
    },
    "add": {
      "template": "let {{name}}: {{type}} = {{inputs:0}} + {{inputs:1}};"
    },
    "multiply": {
      "template": "let {{name}}: {{type}} = {{inputs:0}} * {{inputs:1}};"
    },
    "subtract": {
      "template": "let {{name}}: {{type}} = {{inputs:0}} - {{inputs:1}};"
    },
    "divide": {
      "template": "let {{name}}: {{type}} = {{inputs:0}} / {{inputs:1}};"
    },
    "reroute": {
      "template": "let {{name}}: {{type}} = {{inputs:0}};"
    },
    "select": {
      "template": "let {{name}}: {{type}} = mix({{inputs:2}}, {{inputs:1}}, step(0.5, {{inputs:0}}));"
    },
    "dot": {
      "template": "let {{name}}: f32 = dot({{inputs:0}}, {{inputs:1}});"
    },
    "normalize": {
      "template": "let {{name}}: {{type}} = normalize({{inputs:0}});"
    },
    "sin": {
      "template": "let {{name}}: {{type}} = sin({{inputs:0}});"
    },
    "bitangent_vector": { "template": "let {{name}}_N: vec3<f32> = vec3<f32>(0.0, 0.0, 1.0);\nlet {{name}}_up: vec3<f32> = vec3<f32>(0.0, 1.0, 0.0);\nlet {{name}}_T: vec3<f32> = normalize(cross({{name}}_up, {{name}}_N));\nlet {{name}}: vec3<f32> = cross({{name}}_N, {{name}}_T);",
      "properties": { "space": { "world": { "template": "" }, "object": { "template": "" }, "view": { "template": "" }, "tangent": { "template": "" } } }
    },
    "camera_position": { "template": "let {{name}}: vec3<f32> = vec3<f32>(0.0, 0.0, 0.0);",
      "properties": { "space": { "world": { "template": "" }, "object": { "template": "" }, "tangent": { "template": "" } } }
    },
    "derivative_width": { "template": "let {{name}}: {{type}} = fwidth({{inputs:0}});" },
    "derivative_x": { "template": "let {{name}}: {{type}} = dpdx({{inputs:0}});" },
    "derivative_y": { "template": "let {{name}}: {{type}} = dpdy({{inputs:0}});" },
    "instance_id": { "template": "let {{name}}: f32 = 0.0;" },
    "fresnel": { "template": "let {{name}}_a: vec3<f32> = normalize(vec3<f32>({{inputs:0}}));\nlet {{name}}_b: vec3<f32> = normalize(vec3<f32>({{inputs:1}}));\nlet {{name}}_base: f32 = {{inputs:2}};\nlet {{name}}_scale: f32 = {{inputs:3}};\nlet {{name}}_power: f32 = {{inputs:4}};\nlet {{name}}: f32 = clamp({{name}}_base + {{name}}_scale * pow(max(0.0, 1.0 - dot({{name}}_a, {{name}}_b)), {{name}}_power), 0.0, 1.0);" },
    "equal": { "template": "let {{name}}: f32 = select(0.0, 1.0, abs({{inputs:0}} - {{inputs:1}}) <= {{inputs:2}});" },
    "greater_than": { "template": "let {{name}}: f32 = select(0.0, 1.0, {{inputs:0}} > {{inputs:1}});" },
    "less_than": { "template": "let {{name}}: f32 = select(0.0, 1.0, {{inputs:0}} < {{inputs:1}});" },
    "abs": { "template": "let {{name}}: {{type}} = abs({{inputs:0}});" },
    "acos": { "template": "let {{name}}: {{type}} = acos({{inputs:0}});" },
    "asin": { "template": "let {{name}}: {{type}} = asin({{inputs:0}});" },
    "atan": { "template": "let {{name}}: {{type}} = atan({{inputs:0}});" },
    "atan2": { "template": "let {{name}}: f32 = atan2({{inputs:0}}, {{inputs:1}});" },
    "ceil": { "template": "let {{name}}: {{type}} = ceil({{inputs:0}});" },
    "clamp": { "template": "let {{name}}: {{type}} = clamp({{inputs:0}}, {{inputs:1}}, {{inputs:2}});" },
    "combine2": { "template": "let {{name}}: vec2<f32> = vec2<f32>({{inputs:0}}, {{inputs:1}});" },
    "combine3": { "template": "let {{name}}: vec3<f32> = vec3<f32>({{inputs:0}}, {{inputs:1}}, {{inputs:2}});" },
    "combine4": { "template": "let {{name}}: vec4<f32> = vec4<f32>({{inputs:0}}, {{inputs:1}}, {{inputs:2}}, {{inputs:3}});" },
    "cos": { "template": "let {{name}}: {{type}} = cos({{inputs:0}});" },
    "cross": { "template": "let {{name}}: vec3<f32> = cross({{inputs:0}}, {{inputs:1}});" },
    "exp": { "template": "let {{name}}: {{type}} = exp({{inputs:0}});" },
    "floor": { "template": "let {{name}}: {{type}} = floor({{inputs:0}});" },
    "fract": { "template": "let {{name}}: {{type}} = fract({{inputs:0}});" },
    "inversesqrt": { "template": "let {{name}}: {{type}} = inverseSqrt({{inputs:0}});" },
    "length2": { "template": "let {{name}}: f32 = length({{inputs:0}});" },
    "length3": { "template": "let {{name}}: f32 = length({{inputs:0}});" },
    "lerp": { "template": "let {{name}}: {{type}} = mix({{inputs:0}}, {{inputs:1}}, {{inputs:2}});" },
    "log": { "template": "let {{name}}: {{type}} = log({{inputs:0}});" },
    "log2": { "template": "let {{name}}: {{type}} = log2({{inputs:0}});" },
    "max": { "template": "let {{name}}: {{type}} = max({{inputs:0}}, {{inputs:1}});" },
    "min": { "template": "let {{name}}: {{type}} = min({{inputs:0}}, {{inputs:1}});" },
    "negate": { "template": "let {{name}}: {{type}} = -({{inputs:0}});" },
    "oneminus": { "template": "let {{name}}: {{type}} = {{type}}(1.0) - {{inputs:0}};" },
    "power": { "template": "let {{name}}: {{type}} = pow({{inputs:0}}, {{inputs:1}});" },
    "radians": { "template": "let {{name}}: {{type}} = radians({{inputs:0}});" },
    "reciprocal": { "template": "let {{name}}: {{type}} = {{type}}(1.0) / {{inputs:0}};" },
    "reflect": { "template": "let {{name}}: vec3<f32> = reflect(vec3<f32>({{inputs:0}}), vec3<f32>({{inputs:1}}));" },
    "remainder": { "template": "let {{name}}: {{type}} = {{inputs:0}} - {{inputs:1}} * floor({{inputs:0}} / {{inputs:1}});" },
    "remap": { "template": "let {{name}}: {{type}} = ({{inputs:0}} - {{inputs:1}}) / ({{inputs:2}} - {{inputs:1}}) * ({{inputs:4}} - {{inputs:3}}) + {{inputs:3}};" },
    "round": { "template": "let {{name}}: {{type}} = round({{inputs:0}});" },
    "saturate": { "template": "let {{name}}: {{type}} = clamp({{inputs:0}}, {{type}}(0.0), {{type}}(1.0));" },
    "separate2": {
      "template": "let {{name}}: vec2<f32> = {{inputs:0}};",
      "outputs": { "x": "{{name}}.x", "y": "{{name}}.y" }
    },
    "separate3": {
      "template": "let {{name}}: vec3<f32> = {{inputs:0}};",
      "outputs": { "x": "{{name}}.x", "y": "{{name}}.y", "z": "{{name}}.z" }
    },
    "separate4": {
      "template": "let {{name}}: vec4<f32> = {{inputs:0}};",
      "outputs": {
        "x": "{{name}}.x", "y": "{{name}}.y", "z": "{{name}}.z", "w": "{{name}}.w",
        "r": "{{name}}.r", "g": "{{name}}.g", "b": "{{name}}.b", "a": "{{name}}.a"
      }
    },
    "smoothstep": { "template": "let {{name}}: {{type}} = smoothstep({{inputs:0}}, {{inputs:1}}, {{inputs:2}});" },
    "sqrt": { "template": "let {{name}}: {{type}} = sqrt({{inputs:0}});" },
    "step": { "template": "let {{name}}: {{type}} = step({{inputs:0}}, {{inputs:1}});" },
    "tan": { "template": "let {{name}}: {{type}} = tan({{inputs:0}});" },
    "normal_vector": { "template": "let {{name}}: vec3<f32> = vec3<f32>(0.0, 0.0, 1.0);",
      "properties": { "space": { "world": { "template": "" }, "object": { "template": "" }, "view": { "template": "" }, "tangent": { "template": "" } } }
    },
    "fbm_noise": { "template": "let {{name}}: f32 = 0.0;" },
    "value_noise": { "template": "let {{name}}: f32 = 0.0;" },
    "screen_depth": { "template": "let {{name}}: f32 = 0.0;" },
    "screen_position": { "template": "let {{name}}: vec4<f32> = vec4<f32>(0.0, 0.0, 0.0, 1.0);" },
    "screen_uv": { "template": "let {{name}}: vec2<f32> = vec2<f32>(0.0, 0.0);" },
    "tangent_vector": { "template": "let {{name}}_N: vec3<f32> = vec3<f32>(0.0, 0.0, 1.0);\nlet {{name}}_up: vec3<f32> = vec3<f32>(0.0, 1.0, 0.0);\nlet {{name}}: vec3<f32> = normalize(cross({{name}}_up, {{name}}_N));",
      "properties": { "space": { "world": { "template": "" }, "object": { "template": "" }, "view": { "template": "" }, "tangent": { "template": "" } } }
    },
    "normal_map_unpack": { "template": "var {{name}}: vec3<f32> = normalize(vec3<f32>({{inputs:0}}) * 2.0 - vec3<f32>(1.0, 1.0, 1.0));\n{{name}} = normalize(mix(vec3<f32>(0.0, 0.0, 1.0), {{name}}, vec3<f32>({{inputs:1}})));",
      "properties": { "space": { "tangent": { "template": "" }, "object": { "template": "" }, "world": { "template": "" } } }
    },
    "parallax": { "template": "let {{name}}_uv: vec2<f32> = vec2<f32>({{inputs:1}});\nlet {{name}}_depth: f32 = 0.5;\nlet {{name}}: vec2<f32> = {{name}}_uv;",
      "outputs": { "uv": "{{name}}", "depth": "{{name}}_depth" }
    },
    "texture": { "template": "/* texture resource placeholder */",
      "properties": { "texture_type": { "data": { "template": "" }, "source_color": { "template": "" }, "hint_normal": { "template": "" } } }
    },
    "texture3d": { "template": "/* texture3d resource placeholder */" },
    "texture_array": { "template": "/* texture_array resource placeholder */" },
    "texture_cube": { "template": "// texture_cube binding not implemented for WGSL target",
      "properties": { "texture_type": { "data": { "template": "" }, "source_hdr": { "template": "" } } }
    },
    "texture_sampler": { "template": "let {{name}}: vec4<f32> = vec4<f32>(0.0);",
      "properties": { "wrap_mode": { "wrap_repeat": { "template": "" }, "wrap_clamp": { "template": "" }, "wrap_mirror": { "template": "" }, "wrap_border": { "template": "" } }, "filter_mode": { "filter_linear": { "template": "" }, "filter_nearest": { "template": "" }, "filter_cubic": { "template": "" } } },
      "outputs": { "rgb": "{{name}}.rgb", "r": "{{name}}.r", "g": "{{name}}.g", "b": "{{name}}.b", "a": "{{name}}.a" }
    },
    "texture_sampler3d": { "template": "let {{name}}: vec4<f32> = vec4<f32>(0.0);",
      "properties": { "wrap_mode": { "wrap_repeat": { "template": "" }, "wrap_clamp": { "template": "" }, "wrap_mirror": { "template": "" }, "wrap_border": { "template": "" } }, "filter_mode": { "filter_linear": { "template": "" }, "filter_nearest": { "template": "" } } },
      "outputs": { "rgb": "{{name}}.rgb", "r": "{{name}}.r", "g": "{{name}}.g", "b": "{{name}}.b", "a": "{{name}}.a" }
    },
    "texture_sampler_array": { "template": "let {{name}}: vec4<f32> = vec4<f32>(0.0);",
      "properties": { "wrap_mode": { "wrap_repeat": { "template": "" }, "wrap_clamp": { "template": "" }, "wrap_mirror": { "template": "" }, "wrap_border": { "template": "" } }, "filter_mode": { "filter_linear": { "template": "" }, "filter_nearest": { "template": "" } } },
      "outputs": { "rgb": "{{name}}.rgb", "r": "{{name}}.r", "g": "{{name}}.g", "b": "{{name}}.b", "a": "{{name}}.a" }
    },
    "texture_sampler_cube": { "template": "let {{name}}: vec4<f32> = vec4<f32>(0.0);",
      "properties": { "filter_mode": { "filter_linear": { "template": "" }, "filter_nearest": { "template": "" } } },
      "outputs": { "rgb": "{{name}}.rgb", "r": "{{name}}.r", "g": "{{name}}.g", "b": "{{name}}.b", "a": "{{name}}.a" }
    },
    "triplanar": { "template": "let {{name}}: vec4<f32> = vec4<f32>(0.0);",
      "properties": { "space": { "world": { "template": "" }, "object": { "template": "" } } },
      "outputs": { "rgb": "{{name}}.rgb", "r": "{{name}}.r", "g": "{{name}}.g", "b": "{{name}}.b", "a": "{{name}}.a" }
    },
    "time": { "template": "let {{name}}: f32 = 0.0;" },
    "uv": { "template": "let {{name}}: vec2<f32> = vec2<f32>(0.0, 0.0);" },
    "uv2": { "template": "let {{name}}: vec2<f32> = vec2<f32>(0.0, 0.0);" },
    "vertex_color": { "template": "let {{name}}: vec4<f32> = vec4<f32>(1.0, 1.0, 1.0, 1.0);" },
    "vertex_normal": { "template": "let {{name}}: vec3<f32> = vec3<f32>(0.0, 0.0, 1.0);" },
    "vertex_output": { "template": "/* vertex output noop for WGSL target */" },
    "vertex_position": { "template": "let {{name}}: vec3<f32> = vec3<f32>(0.0, 0.0, 0.0);" },
    "view_direction": { "template": "let {{name}}: vec3<f32> = vec3<f32>(0.0, 0.0, 1.0);",
      "properties": { "space": { "world": { "template": "" }, "object": { "template": "" }, "tangent": { "template": "" } } }
    },
    "view_position": { "template": "let {{name}}: vec3<f32> = vec3<f32>(0.0, 0.0, 0.0);" },
    "world_position": { "template": "let {{name}}: vec3<f32> = vec3<f32>(0.0, 0.0, 0.0);" },
    "transform": { "template": "// transform not implemented for WGSL target",
      "properties": {
        "vector_type": { "direction": { "template": "" }, "position": { "template": "" } },
        "conversion": {
          "object_to_object": { "template": "" },
          "object_to_world": { "template": "" },
          "object_to_view": { "template": "" },
          "object_to_tangent": { "template": "" },
          "object_to_absolute_world": { "template": "" },
          "object_to_screen": { "template": "" },
          "world_to_object": { "template": "" },
          "world_to_world": { "template": "" },
          "world_to_view": { "template": "" },
          "world_to_tangent": { "template": "" },
          "world_to_absolute_world": { "template": "" },
          "world_to_screen": { "template": "" },
          "view_to_object": { "template": "" },
          "view_to_world": { "template": "" },
          "view_to_view": { "template": "" },
          "view_to_tangent": { "template": "" },
          "view_to_absolute_world": { "template": "" },
          "view_to_screen": { "template": "" },
          "tangent_to_object": { "template": "" },
          "tangent_to_world": { "template": "" },
          "tangent_to_view": { "template": "" },
          "tangent_to_tangent": { "template": "" },
          "tangent_to_absolute_world": { "template": "" },
          "tangent_to_screen": { "template": "" },
          "absolute_world_to_object": { "template": "" },
          "absolute_world_to_world": { "template": "" },
          "absolute_world_to_view": { "template": "" },
          "absolute_world_to_tangent": { "template": "" },
          "absolute_world_to_absolute_world": { "template": "" },
          "absolute_world_to_screen": { "template": "" },
          "screen_to_object": { "template": "" },
          "screen_to_world": { "template": "" },
          "screen_to_view": { "template": "" },
          "screen_to_tangent": { "template": "" },
          "screen_to_absolute_world": { "template": "" },
          "screen_to_screen": { "template": "" }
        }
      }
    }
  },
  "meta": {
    "varing": { "template": "// WGSL has no 'varying' keyword; use @location/@builtin instead. // {{definitaion}}" },
    "exposed": { "template": "{{definition}}" }
  }
}


