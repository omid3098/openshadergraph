{
  "name": "Godot",
  "version": "1.0",
  "file_extensions": [
    "gdshader"
  ],
  "coordinates": {
    "up": "+y",
    "right": "+x",
    "forward": "-z",
    "handedness": "right"
  },
  "nodes": {
    "surface": {
      "template": "shader_type spatial;\n{{meta}}\n{{exposed_nodes}}\n{{internal_nodes}}\n"
    },
    "vertex_pass": {
      "template": "void vertex() {\n{{internal_nodes}}}\n"
    },
    "fragment_pass": {
      "template": "void fragment() {\n{{internal_nodes}}}\n"
    },
    "color": {
      "template": "vec4 {{name}} = vec4({{inputs:0}});"
    },
    "float": {
      "template": "float {{name}} = {{inputs:0}};"
    },
    "float2": {
      "template": "vec2 {{name}} = vec2({{inputs:0}});"
    },
    "float3": {
      "template": "vec3 {{name}} = vec3({{inputs:0}});"
    },
    "float4": {
      "template": "vec4 {{name}} = vec4({{inputs:0}});"
    },
    "fragment_output": {
      "template": "ALBEDO = vec3({{inputs:0}});\nROUGHNESS = {{inputs:1}};\nMETALLIC = {{inputs:2}};\nEMISSION = vec3({{inputs:3}});\nNORMAL = vec3({{inputs:4}});\nALPHA = {{inputs:5}};",
      "properties": {
        "shading_model": {
          "pbr": {
            "template": "",
            "placement": "meta"
          },
          "unlit": {
            "template": "render_mode unshaded;",
            "placement": "meta"
          },
          "toon": {
            "template": "",
            "placement": "meta"
          }
        }
      }
    },
    "add": {
      "template": "{{type}} {{name}} = {{inputs:0}} + {{inputs:1}};"
    },
    "multiply": {
      "template": "{{type}} {{name}} = {{inputs:0}} * {{inputs:1}};"
    },
    "subtract": {
      "template": "{{type}} {{name}} = {{inputs:0}} - {{inputs:1}};"
    },
    "divide": {
      "template": "{{type}} {{name}} = {{inputs:0}} / {{inputs:1}};"
    },
    "remainder": {
      "template": "{{type}} {{name}} = mod({{inputs:0}}, {{inputs:1}});"
    },
    "power": {
      "template": "{{type}} {{name}} = pow({{inputs:0}}, {{inputs:1}});"
    },
    "pow": {
      "template": "{{type}} {{name}} = pow({{inputs:0}}, {{inputs:1}});"
    },
    "max": {
      "template": "{{type}} {{name}} = max({{inputs:0}}, {{inputs:1}});"
    },
    "min": {
      "template": "{{type}} {{name}} = min({{inputs:0}}, {{inputs:1}});"
    },
    "atan2": {
      "template": "float {{name}} = atan({{inputs:0}}, {{inputs:1}});"
    },
    "reflect": {
      "template": "vec3 {{name}} = reflect({{inputs:0}}, {{inputs:1}});"
    },
    "step": {
      "template": "{{type}} {{name}} = step({{inputs:0}}, {{inputs:1}});"
    },
    "cross": {
      "template": "vec3 {{name}} = cross({{inputs:0}}, {{inputs:1}});"
    },
    "dot": {
      "template": "float {{name}} = dot({{inputs:0}}, {{inputs:1}});"
    },
    "lerp": {
      "template": "{{type}} {{name}} = mix({{inputs:0}}, {{inputs:1}}, {{inputs:2}});"
    },
    "abs": {
      "template": "{{type}} {{name}} = abs({{inputs:0}});"
    },
    "acos": {
      "template": "{{type}} {{name}} = acos({{inputs:0}});"
    },
    "asin": {
      "template": "{{type}} {{name}} = asin({{inputs:0}});"
    },
    "atan": {
      "template": "{{type}} {{name}} = atan({{inputs:0}});"
    },
    "ceil": {
      "template": "{{type}} {{name}} = ceil({{inputs:0}});"
    },
    "clamp": {
      "template": "{{type}} {{name}} = clamp({{inputs:0}}, {{inputs:1}}, {{inputs:2}});"
    },
    "cos": {
      "template": "{{type}} {{name}} = cos({{inputs:0}});"
    },
    "exp": {
      "template": "{{type}} {{name}} = exp({{inputs:0}});"
    },
    "floor": {
      "template": "{{type}} {{name}} = floor({{inputs:0}});"
    },
    "fract": {
      "template": "{{type}} {{name}} = fract({{inputs:0}});"
    },
    "inversesqrt": {
      "template": "{{type}} {{name}} = inversesqrt({{inputs:0}});"
    },
    "log": {
      "template": "{{type}} {{name}} = log({{inputs:0}});"
    },
    "log2": {
      "template": "{{type}} {{name}} = log2({{inputs:0}});"
    },
    "negate": {
      "template": "{{type}} {{name}} = -{{inputs:0}};"
    },
    "oneminus": {
      "template": "{{type}} {{name}} = {{type}}(1.0) - {{inputs:0}};"
    },
    "radians": {
      "template": "{{type}} {{name}} = radians({{inputs:0}});"
    },
    "reciprocal": {
      "template": "{{type}} {{name}} = {{type}}(1.0) / {{inputs:0}};"
    },
    "remap": {
      "template": "{{type}} {{name}} = ({{inputs:0}} - {{inputs:1}}) / ({{inputs:2}} - {{inputs:1}}) * ({{inputs:4}} - {{inputs:3}}) + {{inputs:3}};"
    },
    "round": {
      "template": "{{type}} {{name}} = round({{inputs:0}});"
    },
    "saturate": {
      "template": "{{type}} {{name}} = clamp({{inputs:0}}, {{type}}(0.0), {{type}}(1.0));"
    },
    "sin": {
      "template": "{{type}} {{name}} = sin({{inputs:0}});"
    },
    "normalize": {
      "template": "{{type}} {{name}} = normalize({{inputs:0}});"
    },
    "sqrt": {
      "template": "{{type}} {{name}} = sqrt({{inputs:0}});"
    },
    "smoothstep": {
      "template": "{{type}} {{name}} = smoothstep({{inputs:0}}, {{inputs:1}}, {{inputs:2}});"
    },
    "tan": {
      "template": "{{type}} {{name}} = tan({{inputs:0}});"
    },
    "length2": {
      "template": "float {{name}} = length({{inputs:0}});"
    },
    "length3": {
      "template": "float {{name}} = length({{inputs:0}});"
    },
    "separate2": {
      "template": "vec2 {{name}} = {{inputs:0}};",
      "outputs": {
        "x": "{{name}}.x",
        "y": "{{name}}.y"
      }
    },
    "separate3": {
      "template": "vec3 {{name}} = {{inputs:0}};",
      "outputs": {
        "x": "{{name}}.x",
        "y": "{{name}}.y",
        "z": "{{name}}.z"
      }
    },
    "separate4": {
      "template": "vec4 {{name}} = {{inputs:0}};",
      "outputs": {
        "x": "{{name}}.x",
        "y": "{{name}}.y",
        "z": "{{name}}.z",
        "w": "{{name}}.w",
        "r": "{{name}}.r",
        "g": "{{name}}.g",
        "b": "{{name}}.b",
        "a": "{{name}}.a"
      }
    },
    "combine2": {
      "template": "vec2 {{name}} = vec2({{inputs:0}}, {{inputs:1}});"
    },
    "combine3": {
      "template": "vec3 {{name}} = vec3({{inputs:0}}, {{inputs:1}}, {{inputs:2}});"
    },
    "combine4": {
      "template": "vec4 {{name}} = vec4({{inputs:0}}, {{inputs:1}}, {{inputs:2}}, {{inputs:3}});"
    },
    "time": {
      "template": "float {{name}} = TIME;"
    },
    "texture": {
      "template": "sampler2D {{name}}{{property:texture_type}};",
      "properties": {
        "texture_type": {
          "data": { "template": "" },
          "source_color": { "template": ": source_color" },
          "hint_normal": { "template": ": hint_normal" }
        }
      }
    },
    "texture_sampler": {
      "template": "{{property:wrap_mode}}\n{{property:filter_mode}}\nvec4 {{name}} = texture({{inputs:0}}, {{inputs:1}});",
      "properties": {
        "wrap_mode": {
          "wrap_repeat": {
            "template": "// wrap: repeat"
          },
          "wrap_clamp": {
            "template": "// wrap: clamp"
          },
          "wrap_mirror": {
            "template": "// wrap: mirror"
          },
          "wrap_border": {
            "template": "// wrap: border"
          }
        },
        "filter_mode": {
          "filter_linear": {
            "template": "// filter: linear"
          },
          "filter_nearest": {
            "template": "// filter: nearest"
          },
          "filter_cubic": {
            "template": "// filter: cubic"
          }
        }
      },
      "outputs": {
        "rgb": "{{name}}.rgb",
        "r": "{{name}}.r",
        "g": "{{name}}.g",
        "b": "{{name}}.b",
        "a": "{{name}}.a"
      }
    },
    "vertex_color": {
      "template": "vec4 {{name}} = COLOR;"
    },
    "vertex_position": {
      "template": "vec3 {{name}} = VERTEX;"
    },
    "uv": {
      "template": "vec2 {{name}} = UV;"
    },
    "uv2": {
      "template": "vec2 {{name}} = UV2;"
    },
    "vertex_normal": {
      "template": "vec3 {{name}} = NORMAL;"
    },
    "normal_vector": {
      "template": "vec3 {{name}} = {{property:space}};",
      "properties": {
        "space": {
          "world": { "template": "NORMAL" },
          "object": { "template": "NORMAL" },
          "tangent": { "template": "NORMAL" }
        }
      }
    },
    "camera_position": {
      "template": "vec3 {{name}} = {{property:space}};",
      "properties": {
        "space": {
          "world": { "template": "CAMERA_POSITION_WORLD" },
          "object": { "template": "CAMERA_POSITION_WORLD" },
          "tangent": { "template": "CAMERA_POSITION_WORLD" }
        }
      }
    },
    "view_direction": {
      "template": "vec3 {{name}} = {{property:space}};",
      "properties": {
        "space": {
          "world": { "template": "VIEW" },
          "object": { "template": "VIEW" },
          "tangent": { "template": "VIEW" }
        }
      }
    },
    "vertex_output": {
      "template": "VERTEX = VERTEX + vec3({{inputs:0}});\nNORMAL = vec3({{inputs:1}});\nCOLOR = vec4({{inputs:2}});"
    }
  },
  "meta": {
    "blend_mode_transparent": {
      "template": "render_mode blend_mix;"
    },
    "blend_mode_opaque": {
      "template": ""
    },
    "alpha_mode_SrcAlpha_OneMinusSrcAlpha": {
      "template": "render_mode blend_mul;"
    },
    "shading_unlit": {
      "template": "render_mode unshaded;"
    },
    "varing": {
      "template": "varing {{definitaion}}"
    },
    "exposed": {
      "template": "uniform {{definition}}"
    }
  }
}
