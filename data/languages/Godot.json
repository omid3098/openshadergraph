    "value_noise": {
      "template": "vec3 {{name}}_p = vec3({{inputs:0}}) * {{inputs:1}} + vec3({{inputs:2}});\nvec3 {{name}}_i = floor({{name}}_p);\nvec3 {{name}}_f = fract({{name}}_p);\n{{name}}_f = {{name}}_f * {{name}}_f * (3.0 - 2.0 * {{name}}_f);\nfloat {{name}}_n000 = fract(sin(dot({{name}}_i + vec3(0.0, 0.0, 0.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\nfloat {{name}}_n100 = fract(sin(dot({{name}}_i + vec3(1.0, 0.0, 0.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\nfloat {{name}}_n010 = fract(sin(dot({{name}}_i + vec3(0.0, 1.0, 0.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\nfloat {{name}}_n110 = fract(sin(dot({{name}}_i + vec3(1.0, 1.0, 0.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\nfloat {{name}}_n001 = fract(sin(dot({{name}}_i + vec3(0.0, 0.0, 1.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\nfloat {{name}}_n101 = fract(sin(dot({{name}}_i + vec3(1.0, 0.0, 1.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\nfloat {{name}}_n011 = fract(sin(dot({{name}}_i + vec3(0.0, 1.0, 1.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\nfloat {{name}}_n111 = fract(sin(dot({{name}}_i + vec3(1.0, 1.0, 1.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\nfloat {{name}}_nx00 = mix({{name}}_n000, {{name}}_n100, {{name}}_f.x);\nfloat {{name}}_nx10 = mix({{name}}_n010, {{name}}_n110, {{name}}_f.x);\nfloat {{name}}_nx01 = mix({{name}}_n001, {{name}}_n101, {{name}}_f.x);\nfloat {{name}}_nx11 = mix({{name}}_n011, {{name}}_n111, {{name}}_f.x);\nfloat {{name}}_nxy0 = mix({{name}}_nx00, {{name}}_nx10, {{name}}_f.y);\nfloat {{name}}_nxy1 = mix({{name}}_nx01, {{name}}_nx11, {{name}}_f.y);\nfloat {{name}} = mix({{name}}_nxy0, {{name}}_nxy1, {{name}}_f.z);"
    },
    "fbm_noise": {
      "template": "vec3 {{name}}_p = vec3({{inputs:0}}) * {{inputs:1}};\nfloat {{name}}_amp = 1.0;\nfloat {{name}}_freq = 1.0;\nfloat {{name}}_sum = 0.0;\nint {{name}}_oct = int(clamp(floor({{inputs:2}} + 0.5), 1.0, 8.0));\nfor (int {{name}}_i = 0; {{name}}_i < 8; {{name}}_i++) {\n  if ({{name}}_i >= {{name}}_oct) break;\n  vec3 {{name}}_pp = {{name}}_p * {{name}}_freq;\n  vec3 {{name}}_i3 = floor({{name}}_pp);\n  vec3 {{name}}_f3 = fract({{name}}_pp);\n  {{name}}_f3 = {{name}}_f3 * {{name}}_f3 * (3.0 - 2.0 * {{name}}_f3);\n  float {{name}}_n000 = fract(sin(dot({{name}}_i3 + vec3(0.0, 0.0, 0.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\n  float {{name}}_n100 = fract(sin(dot({{name}}_i3 + vec3(1.0, 0.0, 0.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\n  float {{name}}_n010 = fract(sin(dot({{name}}_i3 + vec3(0.0, 1.0, 0.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\n  float {{name}}_n110 = fract(sin(dot({{name}}_i3 + vec3(1.0, 1.0, 0.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\n  float {{name}}_n001 = fract(sin(dot({{name}}_i3 + vec3(0.0, 0.0, 1.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\n  float {{name}}_n101 = fract(sin(dot({{name}}_i3 + vec3(1.0, 0.0, 1.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\n  float {{name}}_n011 = fract(sin(dot({{name}}_i3 + vec3(0.0, 1.0, 1.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\n  float {{name}}_n111 = fract(sin(dot({{name}}_i3 + vec3(1.0, 1.0, 1.0), vec3(127.1, 311.7, 74.7))) * 43758.5453);\n  float {{name}}_nx00 = mix({{name}}_n000, {{name}}_n100, {{name}}_f3.x);\n  float {{name}}_nx10 = mix({{name}}_n010, {{name}}_n110, {{name}}_f3.x);\n  float {{name}}_nx01 = mix({{name}}_n001, {{name}}_n101, {{name}}_f3.x);\n  float {{name}}_nx11 = mix({{name}}_n011, {{name}}_n111, {{name}}_f3.x);\n  float {{name}}_nxy0 = mix({{name}}_nx00, {{name}}_nx10, {{name}}_f3.y);\n  float {{name}}_nxy1 = mix({{name}}_nx01, {{name}}_nx11, {{name}}_f3.y);\n  float {{name}}_noise = mix({{name}}_nxy0, {{name}}_nxy1, {{name}}_f3.z);\n  {{name}}_sum += {{name}}_noise * {{name}}_amp;\n  {{name}}_freq *= {{inputs:4}};\n  {{name}}_amp *= {{inputs:3}};\n}\nfloat {{name}} = {{name}}_sum;"
