          },
          "tangent_to_absolute_world": {
            "template": "vec3({{inputs:0}})"
          },
          "tangent_to_screen": {
            "template": "vec3({{inputs:0}})"
          },
          "absolute_world_to_object": {
            "template": "normalize(inverse(mat3(MODEL_MATRIX)) * vec3({{inputs:0}}))"
          },
          "absolute_world_to_world": {
            "template": "vec3({{inputs:0}})"
          },
          "absolute_world_to_view": {
            "template": "normalize(mat3(VIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "absolute_world_to_tangent": {
            "template": "vec3({{inputs:0}})"
          },
          "absolute_world_to_absolute_world": {
            "template": "vec3({{inputs:0}})"
          },
          "absolute_world_to_screen": {
            "template": "normalize(mat3(PROJECTION_MATRIX * VIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "screen_to_object": {
            "template": "normalize(inverse(mat3(PROJECTION_MATRIX * MODELVIEW_MATRIX)) * vec3({{inputs:0}}))"
          },
          "screen_to_world": {
            "template": "normalize(mat3(INV_VIEW_MATRIX) * inverse(mat3(PROJECTION_MATRIX)) * vec3({{inputs:0}}))"
          },
          "screen_to_view": {
            "template": "normalize(inverse(mat3(PROJECTION_MATRIX)) * vec3({{inputs:0}}))"
          },
          "screen_to_tangent": {
            "template": "vec3({{inputs:0}})"
          },
          "screen_to_absolute_world": {
            "template": "normalize(mat3(INV_VIEW_MATRIX) * inverse(mat3(PROJECTION_MATRIX)) * vec3({{inputs:0}}))"
          },
