    "camera": {
      "template": "vec3 {{name}}_position = CAMERA_POSITION_WORLD;\nvec3 {{name}}_direction = normalize((INV_VIEW_MATRIX * vec4(0.0, 0.0, -1.0, 0.0)).xyz);\nfloat {{name}}_orthographic = PROJECTION_MATRIX[3][3] > 0.5 ? 1.0 : 0.0;\nfloat {{name}}_near_plane;\nfloat {{name}}_far_plane;\n{\n  float m22 = PROJECTION_MATRIX[2][2];\n  float m32 = PROJECTION_MATRIX[3][2];\n  if ({{name}}_orthographic > 0.5) {\n    {{name}}_near_plane = (m32 + 1.0) / m22;\n    {{name}}_far_plane = (m32 - 1.0) / m22;\n  } else {\n    {{name}}_near_plane = m32 / (m22 - 1.0);\n    {{name}}_far_plane = m32 / (m22 + 1.0);\n  }\n}\nvec4 {{name}}_near_clip = PROJECTION_MATRIX * vec4(0.0, 0.0, -{{name}}_near_plane, 1.0);\nvec4 {{name}}_far_clip = PROJECTION_MATRIX * vec4(0.0, 0.0, -{{name}}_far_plane, 1.0);\nfloat {{name}}_near_clip_w = max(abs({{name}}_near_clip.w), 1e-6);\nfloat {{name}}_far_clip_w = max(abs({{name}}_far_clip.w), 1e-6);\nfloat {{name}}_near_ndc = {{name}}_near_clip.z / {{name}}_near_clip_w;\nfloat {{name}}_far_ndc = {{name}}_far_clip.z / {{name}}_far_clip_w;\nfloat {{name}}_z_buffer_sign = sign({{name}}_far_ndc - {{name}}_near_ndc);\nif ({{name}}_z_buffer_sign == 0.0) {\n  {{name}}_z_buffer_sign = 1.0;\n}\nfloat {{name}}_width = 0.0;\nfloat {{name}}_height = 0.0;\nif ({{name}}_orthographic > 0.5) {\n  float sx = PROJECTION_MATRIX[0][0];\n  float sy = PROJECTION_MATRIX[1][1];\n  if (abs(sx) > 1e-6) {\n    {{name}}_width = 2.0 / sx;\n  }\n  if (abs(sy) > 1e-6) {\n    {{name}}_height = 2.0 / sy;\n  }\n}",
      "outputs": {
        "position": "{{name}}_position",
        "direction": "{{name}}_direction",
        "orthographic": "{{name}}_orthographic",
        "near plane": "{{name}}_near_plane",
        "far plane": "{{name}}_far_plane",
