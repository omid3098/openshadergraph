{
  "name": "Godot",
  "version": "4.5-stable",
  "file_extensions": [
    "gdshader"
  ],
  "coordinates": {
    "up": "+y",
    "right": "+x",
    "forward": "-z",
    "handedness": "right"
  },
  "types": {
    "float": { "code": "float", "constructor": "float", "zero": "0.0", "components": 1 },
    "float2": { "code": "vec2", "constructor": "vec2", "zero": "vec2(0.0)", "components": 2 },
    "float3": { "code": "vec3", "constructor": "vec3", "zero": "vec3(0.0)", "components": 3 },
    "float4": { "code": "vec4", "constructor": "vec4", "zero": "vec4(0.0)", "components": 4 },
    "matrix2": { "code": "mat2", "constructor": "mat2", "zero": "mat2(1.0)", "components": 2 },
    "matrix3": { "code": "mat3", "constructor": "mat3", "zero": "mat3(1.0)", "components": 3 },
    "matrix4": { "code": "mat4", "constructor": "mat4", "zero": "mat4(1.0)", "components": 4 }
  },
  "capabilities": { "allowRgbSwizzle": true, "vectorCtorScalarSplat": false },
  "nodes": {
    "surface": {
      "template": [
        "shader_type spatial;",
        "{{meta}}",
        "{{exposed_nodes}}",
        "{{internal_nodes}}"]
    },
    "vertex_pass": {
      "template": [
        "void vertex() {",
        "{{internal_nodes}}}"
      ]
    },
    "fragment_pass": {
      "template": [
        "void fragment() {",
        "{{internal_nodes}}}"
      ],
      "properties": {
        "blend_mode": {
          "opaque": { "template": "", "placement": "meta" },
          "transparent": { "template": "render_mode blend_mix;", "placement": "meta" },
          "add": { "template": "render_mode blend_add;", "placement": "meta" },
          "multiply": { "template": "render_mode blend_mul;", "placement": "meta" }
        }
      }
    },
    "color": {
      "template": "vec4 {{name}} = vec4({{inputs:0}});"
    },
    "float": {
      "template": "float {{name}} = {{inputs:0}};"
    },
    "float2": {
      "template": "vec2 {{name}} = vec2({{inputs:0}});"
    },
    "float3": {
      "template": "vec3 {{name}} = vec3({{inputs:0}});"
    },
    "float4": {
      "template": "vec4 {{name}} = vec4({{inputs:0}});"
    },
    "fragment_output": {
      "template": [
        "ALBEDO = vec3({{inputs:0}});",
        "NORMAL = vec3({{inputs:4}});",
        "ROUGHNESS = {{inputs:1}};",
        "METALLIC = {{inputs:2}};",
        "SPECULAR = {{inputs:6}};",
        "AO = {{inputs:7}};",
        "AO_LIGHT_AFFECT = {{inputs:8}};",
        "CLEARCOAT = {{inputs:9}};",
        "CLEARCOAT_ROUGHNESS = {{inputs:10}};",
        "SSS_STRENGTH = {{inputs:13}};",
        "SSS_TRANSMITTANCE_COLOR = vec4({{inputs:14}}, 1.0);",
        "ANISOTROPY = {{inputs:17}};",
        "ANISOTROPY_FLOW = vec3({{inputs:18}}).xy;",
        "EMISSION = vec3({{inputs:3}}) * {{inputs:23}};",
        "{{property:enable_sheen}}",
        "ALPHA = {{inputs:5}};"
      ],
      "properties": {
        "shading_model": {
          "pbr": {
            "template": "",
            "placement": "meta"
          },
          "unlit": {
            "template": "render_mode unshaded;",
            "placement": "meta"
          },
          "toon": {
            "template": "",
            "placement": "meta"
          }
        },
        "enable_transmission": { "true": { "template": "render_mode transmission;", "placement": "meta" } },
        "enable_sss": { "true": { "template": "render_mode subsurface_scattering;", "placement": "meta" } },
        "enable_sheen": { "true": { "template": "float _osg_NoV = clamp(dot(normalize(NORMAL), normalize(VIEW)), 0.0, 1.0);\nvec3 _osg_sheen = vec3({{inputs:16}}) * {{inputs:15}} * pow(1.0 - _osg_NoV, 4.0);\nALBEDO = clamp(ALBEDO + _osg_sheen, vec3(0.0), vec3(1.0));" } },
        "enable_anisotropy": { "true": { "template": "render_mode anisotropic;", "placement": "meta" } },
        "enable_refraction": { "true": { "template": "render_mode refraction;", "placement": "meta" } },
        "enable_backlight": { "true": { "template": "render_mode backlight;", "placement": "meta" } }
      }
    },
    "add": {
      "template": "{{type}} {{name}} = {{inputs:0}} + {{inputs:1}};"
    },
    "multiply": {
      "template": "{{type}} {{name}} = {{inputs:0}} * {{inputs:1}};"
    },
    "subtract": {
      "template": "{{type}} {{name}} = {{inputs:0}} - {{inputs:1}};"
    },
    "divide": {
      "template": "{{type}} {{name}} = {{inputs:0}} / {{inputs:1}};"
    },
    "remainder": {
      "template": "{{type}} {{name}} = mod({{inputs:0}}, {{inputs:1}});"
    },
    "power": {
      "template": "{{type}} {{name}} = pow({{inputs:0}}, {{inputs:1}});"
    },
    "max": {
      "template": "{{type}} {{name}} = max({{inputs:0}}, {{inputs:1}});"
    },
    "min": {
      "template": "{{type}} {{name}} = min({{inputs:0}}, {{inputs:1}});"
    },
    "greater_than": {
      "template": "float {{name}} = {{inputs:0}} > {{inputs:1}} ? 1.0 : 0.0;"
    },
    "less_than": {
      "template": "float {{name}} = {{inputs:0}} < {{inputs:1}} ? 1.0 : 0.0;"
    },
    "equal": {
      "template": "float {{name}} = abs({{inputs:0}} - {{inputs:1}}) <= {{inputs:2}} ? 1.0 : 0.0;"
    },
    "reroute": {
      "template": "{{type}} {{name}} = {{inputs:0}};"
    },
    "select": {
      "template": "{{type}} {{name}} = mix({{inputs:2}}, {{inputs:1}}, step(0.5, {{inputs:0}}));"
    },
    "atan2": {
      "template": "float {{name}} = atan({{inputs:0}}, {{inputs:1}});"
    },
    "reflect": {
      "template": "vec3 {{name}} = reflect({{inputs:0}}, {{inputs:1}});"
    },
    "fresnel": {
      "template": "float {{name}} = clamp({{inputs:2}} + {{inputs:3}} * pow(max(0.0, 1.0 - dot(normalize({{inputs:0}}), normalize({{inputs:1}}))), {{inputs:4}}), 0.0, 1.0);"
    },
    "step": {
      "template": "{{type}} {{name}} = step({{inputs:0}}, {{inputs:1}});"
    },
    "cross": {
      "template": "vec3 {{name}} = cross({{inputs:0}}, {{inputs:1}});"
    },
    "dot": {
      "template": "float {{name}} = dot({{inputs:0}}, {{inputs:1}});"
    },
    "lerp": {
      "template": "{{type}} {{name}} = mix({{inputs:0}}, {{inputs:1}}, {{inputs:2}});"
    },
    "abs": {
      "template": "{{type}} {{name}} = abs({{inputs:0}});"
    },
    "acos": {
      "template": "{{type}} {{name}} = acos({{inputs:0}});"
    },
    "asin": {
      "template": "{{type}} {{name}} = asin({{inputs:0}});"
    },
    "atan": {
      "template": "{{type}} {{name}} = atan({{inputs:0}});"
    },
    "ceil": {
      "template": "{{type}} {{name}} = ceil({{inputs:0}});"
    },
    "clamp": {
      "template": "{{type}} {{name}} = clamp({{inputs:0}}, {{inputs:1}}, {{inputs:2}});"
    },
    "cos": {
      "template": "{{type}} {{name}} = cos({{inputs:0}});"
    },
    "exp": {
      "template": "{{type}} {{name}} = exp({{inputs:0}});"
    },
    "floor": {
      "template": "{{type}} {{name}} = floor({{inputs:0}});"
    },
    "fract": {
      "template": "{{type}} {{name}} = fract({{inputs:0}});"
    },
    "inversesqrt": {
      "template": "{{type}} {{name}} = inversesqrt({{inputs:0}});"
    },
    "log": {
      "template": "{{type}} {{name}} = log({{inputs:0}});"
    },
    "log2": {
      "template": "{{type}} {{name}} = log2({{inputs:0}});"
    },
    "negate": {
      "template": "{{type}} {{name}} = -{{inputs:0}};"
    },
    "oneminus": {
      "template": "{{type}} {{name}} = {{type}}(1.0) - {{inputs:0}};"
    },
    "radians": {
      "template": "{{type}} {{name}} = radians({{inputs:0}});"
    },
    "reciprocal": {
      "template": "{{type}} {{name}} = {{type}}(1.0) / {{inputs:0}};"
    },
    "remap": {
      "template": "{{type}} {{name}} = ({{inputs:0}} - {{inputs:1}}) / ({{inputs:2}} - {{inputs:1}}) * ({{inputs:4}} - {{inputs:3}}) + {{inputs:3}};"
    },
    "round": {
      "template": "{{type}} {{name}} = round({{inputs:0}});"
    },
    "saturate": {
      "template": "{{type}} {{name}} = clamp({{inputs:0}}, {{type}}(0.0), {{type}}(1.0));"
    },
    "sin": {
      "template": "{{type}} {{name}} = sin({{inputs:0}});"
    },
    "normalize": {
      "template": "{{type}} {{name}} = normalize({{inputs:0}});"
    },
    "sqrt": {
      "template": "{{type}} {{name}} = sqrt({{inputs:0}});"
    },
    "smoothstep": {
      "template": "{{type}} {{name}} = smoothstep({{inputs:0}}, {{inputs:1}}, {{inputs:2}});"
    },
    "tan": {
      "template": "{{type}} {{name}} = tan({{inputs:0}});"
    },
    "length2": {
      "template": "float {{name}} = length({{inputs:0}});"
    },
    "length3": {
      "template": "float {{name}} = length({{inputs:0}});"
    },
    "separate2": {
      "template": "vec2 {{name}} = {{inputs:0}}.xy;",
      "outputs": {
        "x": "{{name}}.x",
        "y": "{{name}}.y"
      }
    },
    "separate3": {
      "template": "vec3 {{name}} = {{inputs:0}};",
      "outputs": {
        "x": "{{name}}.x",
        "y": "{{name}}.y",
        "z": "{{name}}.z"
      }
    },
    "separate4": {
      "template": "vec4 {{name}} = {{inputs:0}};",
      "outputs": {
        "x": "{{name}}.x",
        "y": "{{name}}.y",
        "z": "{{name}}.z",
        "w": "{{name}}.w",
        "r": "{{name}}.r",
        "g": "{{name}}.g",
        "b": "{{name}}.b",
        "a": "{{name}}.a"
      }
    },
    "combine2": {
      "template": "vec2 {{name}} = vec2({{inputs:0}}, {{inputs:1}});"
    },
    "combine3": {
      "template": "vec3 {{name}} = vec3({{inputs:0}}, {{inputs:1}}, {{inputs:2}});"
    },
    "combine4": {
      "template": "vec4 {{name}} = vec4({{inputs:0}}, {{inputs:1}}, {{inputs:2}}, {{inputs:3}});"
    },
    "time": {
      "template": "float {{name}} = TIME;"
    },
    "texture": {
      "template": "sampler2D {{name}}{{property:texture_type}};",
      "properties": {
        "texture_type": {
          "data": {
            "template": ""
          },
          "source_color": {
            "template": ": source_color"
          },
          "hint_normal": {
            "template": ": hint_normal"
          }
        }
      }
    },
    "texture_cube": {
      "template": "samplerCube {{name}}{{property:texture_type}};",
      "properties": {
        "texture_type": {
          "data": {
            "template": ""
          },
          "source_hdr": {
            "template": ""
          }
        }
      }
    },
    "texture_sampler": {
      "template": "{{property:wrap_mode}}\n{{property:filter_mode}}\nvec4 {{name}} = texture({{inputs:0}}, {{inputs:1}});",
      "properties": {
        "wrap_mode": {
          "wrap_repeat": {
            "template": "// wrap: repeat"
          },
          "wrap_clamp": {
            "template": "// wrap: clamp"
          },
          "wrap_mirror": {
            "template": "// wrap: mirror"
          },
          "wrap_border": {
            "template": "// wrap: border"
          }
        },
        "filter_mode": {
          "filter_linear": {
            "template": "// filter: linear"
          },
          "filter_nearest": {
            "template": "// filter: nearest"
          },
          "filter_cubic": {
            "template": "// filter: cubic"
          }
        }
      },
      "outputs": {
        "rgb": "{{name}}.rgb",
        "r": "{{name}}.r",
        "g": "{{name}}.g",
        "b": "{{name}}.b",
        "a": "{{name}}.a"
      }
    },
    "texture_sampler_cube": {
      "template": "{{property:filter_mode}}\nvec4 {{name}} = texture({{inputs:0}}, normalize({{inputs:1}}));",
      "properties": {
        "filter_mode": {
          "filter_linear": {
            "template": "// filter: linear"
          },
          "filter_nearest": {
            "template": "// filter: nearest"
          }
        }
      },
      "outputs": {
        "rgb": "{{name}}.rgb",
        "r": "{{name}}.r",
        "g": "{{name}}.g",
        "b": "{{name}}.b",
        "a": "{{name}}.a"
      }
    },
    "vertex_color": {
      "template": "vec4 {{name}} = COLOR;"
    },
    "vertex_position": {
      "template": "vec3 {{name}} = VERTEX;"
    },
    "uv": {
      "template": "vec2 {{name}} = UV;"
    },
    "uv2": {
      "template": "vec2 {{name}} = UV2;"
    },
    "vertex_normal": {
      "template": "vec3 {{name}} = NORMAL;"
    },
    "normal_vector": {
      "template": "vec3 {{name}} = {{property:space}};",
      "properties": {
        "space": {
          "world": {
            "template": "normalize(mat3(INV_VIEW_MATRIX) * NORMAL)"
          },
          "object": {
            "template": "normalize(inverse(MODEL_NORMAL_MATRIX) * (mat3(INV_VIEW_MATRIX) * NORMAL))"
          },
          "view": {
            "template": "NORMAL"
          },
          "tangent": {
            "template": "vec3(0.0, 0.0, 1.0)"
          }
        }
      }
    },
    "transform": {
      "template": "vec3 {{name}} = {{property:vector_type}};",
      "properties": {
        "vector_type": {
          "direction": {
            "template": "{{property:conversion_dir}}"
          },
          "position": {
            "template": "{{property:conversion_pos}}"
          }
        },
        "conversion": {
          "object_to_object": {
            "template": "vec3({{inputs:0}})"
          },
          "object_to_world": {
            "template": "normalize(mat3(MODEL_MATRIX) * vec3({{inputs:0}}))"
          },
          "object_to_view": {
            "template": "normalize(mat3(MODELVIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "object_to_tangent": {
            "template": "vec3({{inputs:0}})"
          },
          "object_to_absolute_world": {
            "template": "normalize(mat3(MODEL_MATRIX) * vec3({{inputs:0}}))"
          },
          "object_to_screen": {
            "template": "normalize(mat3(PROJECTION_MATRIX * MODELVIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "world_to_object": {
            "template": "normalize(inverse(mat3(MODEL_MATRIX)) * vec3({{inputs:0}}))"
          },
          "world_to_world": {
            "template": "vec3({{inputs:0}})"
          },
          "world_to_view": {
            "template": "normalize(mat3(VIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "world_to_tangent": {
            "template": "vec3({{inputs:0}})"
          },
          "world_to_absolute_world": {
            "template": "vec3({{inputs:0}})"
          },
          "world_to_screen": {
            "template": "normalize(mat3(PROJECTION_MATRIX * VIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "view_to_object": {
            "template": "normalize(inverse(mat3(MODELVIEW_MATRIX)) * vec3({{inputs:0}}))"
          },
          "view_to_world": {
            "template": "normalize(mat3(INV_VIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "view_to_view": {
            "template": "vec3({{inputs:0}})"
          },
          "view_to_tangent": {
            "template": "vec3({{inputs:0}})"
          },
          "view_to_absolute_world": {
            "template": "normalize(mat3(INV_VIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "view_to_screen": {
            "template": "normalize(mat3(PROJECTION_MATRIX) * vec3({{inputs:0}}))"
          },
          "tangent_to_object": {
            "template": "vec3({{inputs:0}})"
          },
          "tangent_to_world": {
            "template": "vec3({{inputs:0}})"
          },
          "tangent_to_view": {
            "template": "vec3({{inputs:0}})"
          },
          "tangent_to_tangent": {
            "template": "vec3({{inputs:0}})"
          },
          "tangent_to_absolute_world": {
            "template": "vec3({{inputs:0}})"
          },
          "tangent_to_screen": {
            "template": "vec3({{inputs:0}})"
          },
          "absolute_world_to_object": {
            "template": "normalize(inverse(mat3(MODEL_MATRIX)) * vec3({{inputs:0}}))"
          },
          "absolute_world_to_world": {
            "template": "vec3({{inputs:0}})"
          },
          "absolute_world_to_view": {
            "template": "normalize(mat3(VIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "absolute_world_to_tangent": {
            "template": "vec3({{inputs:0}})"
          },
          "absolute_world_to_absolute_world": {
            "template": "vec3({{inputs:0}})"
          },
          "absolute_world_to_screen": {
            "template": "normalize(mat3(PROJECTION_MATRIX * VIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "screen_to_object": {
            "template": "normalize(inverse(mat3(PROJECTION_MATRIX * MODELVIEW_MATRIX)) * vec3({{inputs:0}}))"
          },
          "screen_to_world": {
            "template": "normalize(mat3(INV_VIEW_MATRIX) * inverse(mat3(PROJECTION_MATRIX)) * vec3({{inputs:0}}))"
          },
          "screen_to_view": {
            "template": "normalize(inverse(mat3(PROJECTION_MATRIX)) * vec3({{inputs:0}}))"
          },
          "screen_to_tangent": {
            "template": "vec3({{inputs:0}})"
          },
          "screen_to_absolute_world": {
            "template": "normalize(mat3(INV_VIEW_MATRIX) * inverse(mat3(PROJECTION_MATRIX)) * vec3({{inputs:0}}))"
          },
          "screen_to_screen": {
            "template": "vec3({{inputs:0}})"
          }
        },
        "conversion_dir": {
          "object_to_object": {
            "template": "vec3({{inputs:0}})"
          },
          "object_to_world": {
            "template": "normalize(mat3(MODEL_MATRIX) * vec3({{inputs:0}}))"
          },
          "object_to_view": {
            "template": "normalize(mat3(MODELVIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "object_to_tangent": {
            "template": "vec3({{inputs:0}})"
          },
          "object_to_absolute_world": {
            "template": "normalize(mat3(MODEL_MATRIX) * vec3({{inputs:0}}))"
          },
          "object_to_screen": {
            "template": "normalize(mat3(PROJECTION_MATRIX * MODELVIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "world_to_object": {
            "template": "normalize(inverse(mat3(MODEL_MATRIX)) * vec3({{inputs:0}}))"
          },
          "world_to_world": {
            "template": "vec3({{inputs:0}})"
          },
          "world_to_view": {
            "template": "normalize(mat3(VIEW_MATRIX) * vec3({{inputs:0}}))"
          },
          "world_to_tangent": {
            "template": "vec3({{inputs:0}})"
          },
          "world_to_absolute_world": {
