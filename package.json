{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.tsx",
  "module": "src/index.tsx",
  "scripts": {
    "dev:server": "bun --hot src/index.tsx",
    "dev:watch": "bun run build.ts --sourcemap=inline --minify=false --define.process.env.NODE_ENV=\"development\" --watch",
    "dev:all": "bash -c 'bun run dev:watch & bun run dev:server'",
    "dev": "bun run dev:all",
    "start": "NODE_ENV=production bun src/index.tsx",
    "build": "bun run build.ts --auto-tag",
    "docs:dev": "bash -c 'command -v mkdocs >/dev/null 2>&1 || { echo \"mkdocs not found, run: python -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt\"; exit 1; }; mkdocs serve -a 0.0.0.0:${DOCS_PORT:-8000}'",
    "docs:build": "bash -c 'command -v mkdocs >/dev/null 2>&1 || { echo \"mkdocs not found, run: python -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt\"; exit 1; }; mkdocs build --clean'",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.0",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@xyflow/react": "^12.8.4",
    "bun-plugin-tailwind": "^0.0.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19",
    "react-colorful": "^5.6.1",
    "react-dom": "^19",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^3.0.1",
    "tailwindcss": "^4.0.6",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.170.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "latest",
    "@types/node": "^22.5.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.1"
  }
}
