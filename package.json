{
  "name": "openshadergraph",
  "version": "0.2.0",
  "description": "Engine-agnostic node-based shader graph for authoring shaders with template-driven compilation to multiple targets",
  "author": "OpenShaderGraph Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/omid3098/openshadergraph.git"
  },
  "bugs": {
    "url": "https://github.com/omid3098/openshadergraph/issues"
  },
  "homepage": "https://github.com/omid3098/openshadergraph#readme",
  "keywords": [
    "shader",
    "node-graph",
    "glsl",
    "godot",
    "threejs",
    "visual-shader",
    "shader-editor",
    "material-editor",
    "shader-graph",
    "bun",
    "typescript",
    "reactflow"
  ],
  "private": true,
  "type": "module",
  "main": "src/index.tsx",
  "module": "src/index.tsx",
  "scripts": {
    "dev:server": "bun --hot src/index.tsx",
    "dev:watch": "bun run build.ts --sourcemap=inline --minify=false --define.process.env.NODE_ENV=\"development\" --watch",
    "dev:all": "bash -c 'bun run dev:watch & bun run dev:server'",
    "dev:server:docs": "DOCS_DEV_PROXY=http://127.0.0.1:${DOCS_PORT:-8000} bun --hot src/index.tsx",
    "dev:docs": "bash -c 'bun run docs:dev & bun run dev:watch & bun run dev:server:docs'",
    "dev": "bun run dev:all",
    "start": "NODE_ENV=production bun src/index.tsx",
    "build": "bun run build.ts",
    "docs:dev": "bash -c 'command -v mkdocs >/dev/null 2>&1 || { echo \"mkdocs not found, run: python -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt\"; exit 1; }; pids=$(lsof -tiTCP:${DOCS_PORT:-8000} -sTCP:LISTEN || true); if [ -n \"$pids\" ]; then echo \"Killing existing docs process on port ${DOCS_PORT:-8000}: $pids\"; kill $pids || kill -9 $pids; fi; mkdocs serve -a 0.0.0.0:${DOCS_PORT:-8000}'",
    "docs:build": "bash -c 'command -v mkdocs >/dev/null 2>&1 || { echo \"mkdocs not found, run: python -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt\"; exit 1; }; mkdocs build --clean'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:all": "PLAYWRIGHT_ALL_BROWSERS=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "bunx playwright install --with-deps chromium",
    "test:e2e:install:all": "bunx playwright install --with-deps",
    "bench": "vitest bench",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "gates": "bun run scripts/gates.ts",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --ci false",
    "validate:godot": "bun run --bun scripts/validateGodot.ts",
    "validate:three": "bun run --bun scripts/validateThree.ts",
    "validate:shaders": "bun run validate:godot && bun run validate:three"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.0",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@xyflow/react": "^12.8.4",
    "bun-plugin-tailwind": "^0.0.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19",
    "react-colorful": "^5.6.1",
    "react-dom": "^19",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss": "^4.0.6",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.170.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@playwright/test": "^1.55.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.2.3",
    "@semantic-release/npm": "^11.0.3",
    "@semantic-release/release-notes-generator": "^13.0.0",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "latest",
    "@types/node": "^22.5.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.34.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.9.2",
    "semantic-release": "^24.2.2",
    "vitest": "^3.2.4"
  }
}
