{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2021", "DOM"],
    "jsx": "react-jsx",
    "allowJs": true,
    // Bundler mode
    "moduleResolution": "bundler",
    "module": "preserve",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    // noUncheckedIndexedAccess disabled - too strict for practical use (causes 150+ errors for array/object access)
    // "noUncheckedIndexedAccess": true,
    // exactOptionalPropertyTypes disabled due to conflicts with third-party libraries (React Flow, Playwright)
    // "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["dist", "node_modules"],
  "files": ["bun-env.d.ts", "src/types/three-shims.d.ts"]
}
